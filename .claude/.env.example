# ─────────────────────────────────────────────────────────────────────────────
# .env.example — committed template. Copy to `.claude/.env` and fill in values:
#
#   Copy-Item .claude/.env.example .claude/.env      (PowerShell)
#   cp .claude/.env.example .claude/.env             (bash)
#
# The real `.claude/.env` is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# GitHub personal access token (gh CLI / GitHub API operations)
GITHUB_TOKEN=

# GitHub repository URL (not secret; convenience reference for tooling/scripts)
GITHUB_PROJECT=https://github.com/badsonstudios/ClaudeMon

# ── Common secrets — uncomment and fill in the ones this project needs ────────
# Claude / Anthropic API key (if this project calls the Claude API)
# ANTHROPIC_API_KEY=

# Database
# DATABASE_URL=
# DB_HOST=
# DB_PORT=
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# Generic API access
# API_BASE_URL=
# API_KEY=

# App credentials / test account
# APP_USERNAME=
# APP_PASSWORD=
